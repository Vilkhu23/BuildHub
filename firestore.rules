rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own state and sub-collections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Support fallback / anonymous access or general public database state for initial load
    match /public_data/{document} {
      allow read, write: if true;
    }
  }
}
