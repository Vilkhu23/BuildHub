rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Global default-deny catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure Siloed User Database Path:
    // Restricts all read, create, update, and delete actions strictly to the authenticated owner of the account.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
